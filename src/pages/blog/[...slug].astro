---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
  <div class="p-4">
    <h1 class="text-2xl font-bold my-4"># {post.data.title}</h1>
    <p class="opacity-50 my-4">
      <i class="fa-solid fa-calendar"></i> {post.data.pubDate.toLocaleDateString()}
      /
      {post.data.tags && post.data.tags.length > 0 && (
      <span class=""><i class="fa-solid fa-tag"></i> 
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tag}`} class="mx-1">#{tag}</a>
        ))}
      </span>
    )}
    </p>
    <article 
      class="prose
            text-justify
            text-zinc-100
            prose-blockquote:text-zinc-100
            prose-blockquote:opacity-75 
            prose-strong:text-zinc-100 
            prose-headings:text-zinc-100 
            prose-pre:text-zinc-100
            prose-pre:border-zinc-100
            prose-pre:border-2
            prose-code:text-zinc-100
            prose-b:text-zinc-100
            prose-a:no-underline
            "
    >
      <Content/>
    </article>
  </div>
</Layout>