---
const { name, link, desc, stack } = Astro.props;
---
<div class="py-4">
    <a href=`${link ?? '#'}` target=`_blank` class="text-xl font-bold">
    {name}
    </a><br>
    <span>{desc}</span><br>
    {stack.map((tech) => (<small class="opacity-75 px-2 rounded-2xl mx-0.5 bg-zinc-700">{tech}</small>)) }
</div>